# ReadyStack agent fleet SSH config
#
# Drop the entries below into your local ~/.ssh/config (Windows:
# C:\Users\<you>\.ssh\config). After installing, you can SSH to any agent by
# its short name, e.g.:
#
#     ssh AgentEPC
#     ssh TomBombadil
#     ssh Fuzz
#
# Three of the agents are on the LAN directly. The other sixteen are libvirt
# guests on the 192.168.122.0/24 bridge and need a ProxyJump through the
# mombadil VM host (192.168.1.124).
#
# Prerequisite: your public key must be present in
# ~/.ssh/authorized_keys on every agent AND on mombadil. Run
# `bash /home/johntdavenport/scripts/push-windows-key.sh` from ExceedBot to
# distribute it to the whole fleet.

# === Jump host (libvirt VM host) ===
Host mombadil
  HostName 192.168.1.124
  User johntdavenport

Host bombadil
  HostName 192.168.1.185
  User johntdavenport

# === Direct-LAN agents ===
Host TomBombadil
  HostName 192.168.1.202
  User readystack

Host Fuzz
  HostName 192.168.1.113
  User johntdavenport

Host Daniel
  HostName 192.168.1.213
  User readystack

# === Agents behind mombadil (libvirt 192.168.122.0/24) ===
