# Spyglass Environment Configuration
# Copy to .env and customize for your VM.

# Required: Role label shown in the Spyglass header
VM_ROLE=DevOps

# Optional: Password for WebUI login. If unset, no auth required.
# AUTH_PASSWORD=mysecretpass

# Optional: Backend port (default 8080)
# PORT=8080

# Optional: Backend bind address (default 127.0.0.1, use 0.0.0.0 for all interfaces)
# HOST=0.0.0.0

# Optional: Enable debug logging (true/false)
# DEBUG=false
